{
  "name": "@root/cordis-webui",
  "private": true,
  "packageManager": "yarn@4.14.1",
  "type": "module",
  "version": "1.0.0",
  "workspaces": [
    "external/*",
    "external/*/external/*",
    "external/*/packages/*",
    "packages/*",
    "plugins/*"
  ],
  "license": "MIT",
  "scripts": {
    "build": "yakumo --import tsx build",
    "lint": "eslint --cache",
    "dev": "node --import tsx packages/online/src/dev",
    "serve": "node --import tsx packages/online/src/serve",
    "test": "yakumo mocha --import tsx -t 10000",
    "test:text": "shx rm -rf coverage && c8 -r text yarn test",
    "test:json": "shx rm -rf coverage && c8 -r json yarn test",
    "test:html": "shx rm -rf coverage && c8 -r html yarn test"
  },
  "devDependencies": {
    "@cordisjs/eslint-config": "^1.1.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.5",
    "c8": "^10.1.3",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "mocha": "^11.7.5",
    "shx": "^0.4.0",
    "tsx": "npm:@cordiverse/tsx@4.19.3-fix.3",
    "typescript": "^5.9.3",
    "yakumo": "^3.1.2",
    "yakumo-esbuild": "^3.0.2",
    "yakumo-mocha": "^3.0.3",
    "yakumo-tsc": "^3.0.1"
  }
}
