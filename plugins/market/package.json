{
  "name": "@cordisjs/plugin-market",
  "description": "Plugin market for Cordis",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./src/*": "./src/*",
    "./client": "./client/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "dist"
  ],
  "author": "Shigma <shigma10826@gmail.com>",
  "license": "MIT",
  "scripts": {
    "lint": "eslint src --ext .ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cordiverse/webui.git",
    "directory": "plugins/market"
  },
  "bugs": {
    "url": "https://github.com/cordiverse/webui/issues"
  },
  "keywords": [
    "cordis",
    "plugin",
    "market",
    "webui"
  ],
  "cordis": {
    "public": [
      "dist"
    ],
    "description": {
      "en": "Install and manage Cordis plugins from the built-in market",
      "zh": "从内置市场安装和管理 Cordis 插件"
    },
    "service": {
      "required": [
        "http",
        "webui"
      ],
      "implements": [
        "installer"
      ]
    }
  },
  "peerDependencies": {
    "@cordisjs/plugin-http": "^1.4.0",
    "@cordisjs/plugin-webui": "^0.4.2",
    "cordis": "^4.0.0-rc.3"
  },
  "devDependencies": {
    "@cordisjs/client": "^0.4.2",
    "@cordisjs/market": "^4.2.5",
    "@cordisjs/plugin-http": "^1.4.0",
    "@cordisjs/plugin-webui": "^0.4.2",
    "@types/semver": "^7.5.8",
    "@types/which-pm-runs": "^1.0.2",
    "cordis": "^4.0.0-rc.3"
  },
  "dependencies": {
    "cosmokit": "^1.8.1",
    "schemastery": "^3.18.0",
    "semver": "^7.6.3",
    "which-pm-runs": "^1.1.0"
  }
}
